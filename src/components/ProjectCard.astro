---
import { Image } from 'astro:assets';
import type { Project } from '../content/projects';
import { statusLabel } from '../content/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const isLinked = Boolean(project.url);
const Tag = isLinked ? 'a' : 'article';
---

<Tag
  {...isLinked
    ? {
        href: project.url,
        target: '_blank',
        rel: 'noopener noreferrer',
      }
    : {}}
  class:list={[
    'group block overflow-hidden rounded-[var(--radius)] border bg-muted',
    'transition-colors duration-150',
    isLinked ? 'cursor-pointer hover:border-muted-foreground/40' : '',
  ]}
>
  <div class="relative aspect-[3/2] overflow-hidden border-b bg-background">
    <Image
      src={project.screenshot}
      alt={project.screenshotAlt}
      widths={[640, 1280, 1600]}
      sizes="(min-width: 768px) 320px, 100vw"
      loading="lazy"
      decoding="async"
      class:list={[
        'h-full w-full object-cover',
        'transition-transform duration-[400ms] ease-out',
        isLinked ? 'group-hover:scale-[1.015]' : '',
      ]}
    />
  </div>

  <div class="flex flex-col gap-1 px-4 py-3.5">
    <div class="flex items-center gap-2">
      <span class="text-[15px] font-medium tracking-tight text-foreground">
        {project.name}
      </span>
      {
        project.status && (
          <span class="rounded-full border bg-background px-2 py-0.5 text-[10px] font-medium text-muted-foreground">
            {statusLabel(project.status)}
          </span>
        )
      }
    </div>
    <p class="text-[13px] leading-relaxed text-muted-foreground">
      {project.description}
    </p>
  </div>
</Tag>
